# ─── Database ────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/authority13?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/authority13?sslmode=require"

# ─── Auth ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ─── Encryption ──────────────────────────────────────
# Must be at least 32 characters. Used to encrypt API keys at rest.
MASTER_KEY="generate-with: openssl rand -base64 32"

# ─── Redis (optional, for pub/sub) ───────────────────
REDIS_URL="redis://default:password@host:6379"

# ─── Google OAuth (optional) ─────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Brave Search API (optional, improves web search) 
# Get a free key at https://api.search.brave.com/
# BRAVE_SEARCH_API_KEY=""
